<script>
function handleFormSubmit(e: Event) {
  e.preventDefault();
  const form = e.target as HTMLFormElement;
  const inp = document.getElementById('emailInput') as HTMLInputElement;
  const msg = document.getElementById('formMessage') as HTMLElement;
  const val = inp.value.trim();

  if (!val || !/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(val)) {
    inp.style.borderColor = '#ff4d4d';
    inp.setAttribute('aria-invalid', 'true');
    inp.focus();
    return;
  }
  inp.style.borderColor = '';
  inp.setAttribute('aria-invalid', 'false');

  const btn = form.querySelector('button[type="submit"]') as HTMLButtonElement;
  btn.textContent = 'Sending…';
  btn.disabled = true;

  setTimeout(() => {
    inp.value = '';
    btn.textContent = '✓ You\'re on the launchpad!';
    btn.style.background = 'linear-gradient(135deg,#22c55e,#16a34a)';
    btn.style.color = '#fff';
    msg.textContent = 'We\'ll be in touch within 1 business day. Check your inbox!';
    msg.style.color = '#86efac';
  }, 900);
}

// Make handleFormSubmit globally accessible (called from inline onsubmit)
(window as any).handleFormSubmit = handleFormSubmit;

// GSAP animations
window.addEventListener('load', () => {
  if (typeof (window as any).gsap === 'undefined') return;
  const gsap = (window as any).gsap;
  const ScrollTrigger = (window as any).ScrollTrigger;
  gsap.registerPlugin(ScrollTrigger);

  const heroTl = gsap.timeline({ defaults: { ease: 'power3.out' } });
  heroTl
    .from('#heroBadge',    { opacity: 0, y: 30, duration: 0.6 })
    .from('#hero-heading', { opacity: 0, y: 45, duration: 0.7 }, '-=0.3')
    .from('.booming-word', { opacity: 0, scale: 0.82, duration: 0.65 }, '-=0.4')
    .from('.hero-sub',     { opacity: 0, y: 24, duration: 0.55 }, '-=0.35')
    .from('.hero-buttons', { opacity: 0, y: 20, duration: 0.5  }, '-=0.3')
    .from('.hero-visual',  { opacity: 0, scale: 0.86, duration: 0.9, ease: 'back.out(1.4)' }, '-=0.7')
    .from('.float-tag',    { opacity: 0, y: 18, stagger: 0.14, duration: 0.5 }, '-=0.55');

  gsap.utils.toArray('.reveal').forEach((el: Element) => {
    gsap.fromTo(el, { opacity: 0, y: 38 }, { opacity: 1, y: 0, duration: 0.72, ease: 'power2.out',
      scrollTrigger: { trigger: el, start: 'top 88%', toggleActions: 'play none none none' } });
  });
  gsap.utils.toArray('.reveal-left').forEach((el: Element) => {
    gsap.fromTo(el, { opacity: 0, x: -50 }, { opacity: 1, x: 0, duration: 0.75, ease: 'power2.out',
      scrollTrigger: { trigger: el, start: 'top 88%', toggleActions: 'play none none none' } });
  });
  gsap.utils.toArray('.reveal-right').forEach((el: Element) => {
    gsap.fromTo(el, { opacity: 0, x: 50 }, { opacity: 1, x: 0, duration: 0.75, ease: 'power2.out',
      scrollTrigger: { trigger: el, start: 'top 88%', toggleActions: 'play none none none' } });
  });
  gsap.utils.toArray('.service-card').forEach((card: Element, i: number) => {
    gsap.fromTo(card, { opacity: 0, y: 52, scale: 0.95 }, { opacity: 1, y: 0, scale: 1, duration: 0.65, ease: 'power2.out',
      delay: (i % 3) * 0.1, scrollTrigger: { trigger: card, start: 'top 91%', toggleActions: 'play none none none' } });
  });
  gsap.utils.toArray('.bento-card').forEach((card: Element, i: number) => {
    gsap.fromTo(card, { opacity: 0, y: 42 }, { opacity: 1, y: 0, duration: 0.65, ease: 'power2.out', delay: i * 0.1,
      scrollTrigger: { trigger: card, start: 'top 91%', toggleActions: 'play none none none' } });
  });
  gsap.utils.toArray('.stat-value').forEach((el: Element) => {
    ScrollTrigger.create({ trigger: el, start: 'top 92%', once: true,
      onEnter: () => gsap.from(el, { scale: 0.65, opacity: 0, duration: 0.55, ease: 'back.out(1.8)' }) });
  });
});
</script>

