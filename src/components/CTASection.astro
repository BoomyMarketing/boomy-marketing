---
/**
 * CTASection.astro — email capture CTA section
 * Used on homepage and most service/local pages.
 *
 * Usage:
 *   <CTASection />
 *   <CTASection
 *     label="📡 Ready for Liftoff?"
 *     heading="Ready to"
 *     headingHighlight="Launch?"
 *     body="Share your email below and we will send over a complimentary strategy session."
 *   />
 */
interface Props {
  label?: string;
  heading?: string;
  headingHighlight?: string;
  body?: string;
  id?: string;
}

const {
  label = '📡 Ready for Liftoff?',
  heading = 'Ready to',
  headingHighlight = 'Launch?',
  body = 'Share your email below and we will send over a complimentary 15-minute strategy session. No sales pitch, no obligation—just a candid look at your single biggest growth opportunity right now.',
  id = 'contact',
} = Astro.props;

const trustItems = [
  { icon: '⭐', text: '5.0 Google Rating' },
  { icon: '🔒', text: 'No Contracts Required' },
  { icon: '⚡', text: 'Results in 30 Days' },
];
---

<section class="cta-section" id={id} aria-labelledby={`${id}-heading`}>
  <div class="cta-inner">
    <div class="section-label reveal" style="margin:0 auto 20px;">{label}</div>
    <h2 id={`${id}-heading`} class="reveal">
      {heading} <span class="gradient-text">{headingHighlight}</span>
    </h2>
    <p class="reveal">{body}</p>

    <form
      class="cta-form reveal"
      id="ctaForm"
      novalidate
      aria-label="Request a free strategy session"
      onsubmit="handleFormSubmit(event)"
    >
      <input
        type="email"
        id="emailInput"
        class="cta-input"
        placeholder="your@email.com"
        aria-label="Your email address"
        autocomplete="email"
        required
      />
      <button type="submit" class="btn btn-cta magnetic-btn" aria-label="Claim free strategy session">
        Claim Free Session
        <svg width="18" height="18" viewBox="0 0 18 18" fill="none" aria-hidden="true">
          <path d="M3.75 9h10.5M10.5 5.25L14.25 9l-3.75 3.75" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </button>
    </form>

    <p class="cta-note reveal" id="formMessage">
      No spam, ever. Unsubscribe any time. We respond within 1 business day.
    </p>

    <div class="cta-trust reveal">
      {trustItems.map(({ icon, text }) => (
        <div class="cta-trust-item">
          <span class="cta-trust-icon" aria-hidden="true">{icon}</span>
          <span>{text}</span>
        </div>
      ))}
    </div>
  </div>
</section>
