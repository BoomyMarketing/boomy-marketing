---
/**
 * LocalPageLayout.astro — layout for /local/{city}/{service}/ pages
 *
 * Extends BaseLayout with:
 *  • LocalBusiness + MarketingAgency schema
 *  • FAQPage schema
 *  • BreadcrumbList (via Breadcrumb component)
 *  • Consistent meta structure for local SEO
 *
 * Usage in src/pages/local/[city]/[service]/index.astro:
 *
 *   <LocalPageLayout page={pageData} faqs={faqItems}>
 *     <!-- page body content -->
 *   </LocalPageLayout>
 */

import BaseLayout from './BaseLayout.astro';
import Breadcrumb from '@components/Breadcrumb.astro';
import type { LocalPageData, FAQItem } from '@data/types';

interface Props {
  page: LocalPageData;
  faqs?: FAQItem[];
  pageStyle?: string;
}

const { page, faqs = [], pageStyle } = Astro.props;

const canonicalUrl = `https://boomymarketing.com${page.canonicalPath}`;

// ─── LocalBusiness + MarketingAgency schema ───────────────────────────────
const localBusinessSchema = {
  "@context": "https://schema.org",
  "@type": ["LocalBusiness", "MarketingAgency"],
  "name": "Boomy Marketing Agency",
  "description": `${page.serviceName} services in ${page.cityName}`,
  "url": canonicalUrl,
  "telephone": "+16473701888",
  "email": "care@boomymarketing.com",
  "address": {
    "@type": "PostalAddress",
    "addressLocality": page.cityName,
    "addressRegion": page.province,
    "addressCountry": "CA",
  },
  "geo": {
    "@type": "GeoCoordinates",
    "latitude": page.geo.latitude,
    "longitude": page.geo.longitude,
  },
  "priceRange": "$$",
  "hasOfferCatalog": {
    "@type": "OfferCatalog",
    "name": page.serviceName,
    "itemListElement": [
      { "@type": "Offer", "name": `${page.serviceName} - Starter`, "price": "$1,500 CAD/mo", "priceCurrency": "CAD" },
      { "@type": "Offer", "name": `${page.serviceName} - Growth`,  "price": "$3,500 CAD/mo", "priceCurrency": "CAD" },
      { "@type": "Offer", "name": `${page.serviceName} - Scale`,   "price": "$7,500 CAD/mo", "priceCurrency": "CAD" },
    ],
  },
  "areaServed": [
    { "@type": "City", "name": page.cityName },
    ...page.nearbyCities.map((c) => ({ "@type": "City", "name": c })),
  ],
  "dateModified": new Date().toISOString().split('T')[0],
};

// ─── FAQPage schema ───────────────────────────────────────────────────────
const faqSchema = faqs.length > 0 ? {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": faqs.map(({ question, answer }) => ({
    "@type": "Question",
    "name": question,
    "acceptedAnswer": { "@type": "Answer", "text": answer },
  })),
} : null;

// ─── Breadcrumb items ─────────────────────────────────────────────────────
const breadcrumbItems = [
  { label: 'Home', href: '/' },
  { label: 'Local', href: '/local' },
  { label: `${page.serviceName} in ${page.cityName}` },
];

// Combine schemas (BaseLayout handles the array)
const schemas = [
  localBusinessSchema,
  ...(faqSchema ? [faqSchema] : []),
];
---

<BaseLayout
  title={page.title}
  description={page.description}
  canonical={canonicalUrl}
  schema={schemas}
  pageStyle={pageStyle}
>
  <Breadcrumb items={breadcrumbItems} />
  <slot />
</BaseLayout>
