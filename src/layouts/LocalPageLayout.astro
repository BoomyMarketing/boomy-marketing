---
/**
 * LocalPageLayout.astro — layout for /local/{city}/{service}/ pages
 *
 * Extends BaseLayout with:
 *  • LocalBusiness + MarketingAgency schema
 *  • FAQPage schema
 *  • BreadcrumbList (via Breadcrumb component)
 *  • Consistent meta structure for local SEO
 *
 * Usage in src/pages/local/[city]/[service]/index.astro:
 *
 *   <LocalPageLayout page={pageData} faqs={faqItems}>
 *     <!-- page body content -->
 *   </LocalPageLayout>
 */

import BaseLayout from './BaseLayout.astro';
import Breadcrumb from '@components/Breadcrumb.astro';
import type { City } from '@data/cities';
import type { LocalService } from '@data/localServices';

interface Props {
  city: City;
  service: LocalService;
  faqs?: Array<{question: string, answer: string}>;
  pageStyle?: string;
}

const { city, service, faqs = [], pageStyle } = Astro.props;

const title = `${service.displayName} in ${city.displayName} | Boomy Marketing`;
const description = `${service.displayName} in ${city.displayName}, ${city.provinceCode}. Boomy Marketing Agency — measurable results, more leads, better ROI. Book a free strategy session.`;
const canonicalUrl = `https://boomymarketing.com/local/${city.slug}/${service.slug}`;

// ─── LocalBusiness + MarketingAgency schema ───────────────────────────────
const localBusinessSchema = {
  "@context": "https://schema.org",
  "@type": ["LocalBusiness", "MarketingAgency"],
  "name": "Boomy Marketing Agency",
  "description": `${service.displayName} services in ${city.displayName}`,
  "url": canonicalUrl,
  "telephone": "+16473701888",
  "email": "care@boomymarketing.com",
  "address": {
    "@type": "PostalAddress",
    "addressLocality": city.displayName,
    "addressRegion": city.provinceCode,
    "addressCountry": "CA",
  },
  "geo": {
    "@type": "GeoCoordinates",
    "latitude": city.latitude,
    "longitude": city.longitude,
  },
  "priceRange": service.priceRange,
  "hasOfferCatalog": {
    "@type": "OfferCatalog",
    "name": service.displayName,
    "itemListElement": service.offers.map(offer => ({
      "@type": "Offer",
      "name": offer.name,
      "price": offer.price,
      "priceCurrency": offer.currency
    }))
  },
  "areaServed": city.areaServed.map(area => ({
    "@type": "City",
    "name": area
  })),
  "dateModified": new Date().toISOString().split('T')[0],
};

// ─── FAQPage schema ───────────────────────────────────────────────────────
const faqSchema = faqs.length > 0 ? {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": faqs.map(({ question, answer }) => ({
    "@type": "Question",
    "name": question,
    "acceptedAnswer": { "@type": "Answer", "text": answer },
  })),
} : null;

// ─── Breadcrumb items ─────────────────────────────────────────────────────
const breadcrumbItems = [
  { label: 'Home', href: '/' },
  { label: 'Local', href: '/local' },
  { label: `${service.displayName} in ${city.displayName}` },
];

// Combine schemas (BaseLayout handles the array)
const schemas = [
  localBusinessSchema,
  ...(faqSchema ? [faqSchema] : []),
];
---

<BaseLayout
  title={title}
  description={description}
  canonical={canonicalUrl}
  schema={schemas}
  pageStyle={pageStyle}
>
  <Breadcrumb items={breadcrumbItems} />
  <slot />
</BaseLayout>
